@startuml
' BD-01-PapelDoSBD.puml
' Visualizar em: https://plantuml.com/

skinparam rectangle {
  BackgroundColor #F0F4F8
  BorderColor #2563EB
}

actor "Usuário Final /\nAplicação Web-Mobile" as USER
actor "Desenvolvedor" as DEV
actor "DBA" as DBA

rectangle "Camada de Aplicação" as APP

package "SGBD (Oracle Database / PostgreSQL)" as SGBD {
  rectangle "Processador de Consultas /\nOtimizador" as OTIM
  rectangle "Gerenciador de Transações (ACID)" as TRANS
  rectangle "Controle de Concorrência" as CONC
  rectangle "Dicionário de Dados / Catálogo" as CAT
  rectangle "Motor de Armazenamento" as ENGINE

  OTIM --> TRANS
  TRANS --> CONC
  CONC --> CAT
  CAT --> ENGINE
}

database "Armazenamento Físico\nTablespaces / Arquivos de Dados" as STORAGE

USER --> APP
DEV --> APP : escreve
DBA --> SGBD : administra
APP --> SGBD : SQL
ENGINE --> STORAGE
@enduml
