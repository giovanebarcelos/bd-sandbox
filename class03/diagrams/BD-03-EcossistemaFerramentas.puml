@startuml
' BD-03-EcossistemaFerramentas.puml
' Visualizar em: https://plantuml.com/

skinparam rectangle {
  BackgroundColor #F0F4F8
  BorderColor #2563EB
}

package "Ferramentas Oracle" as OracleTools {
  rectangle "SQL Developer" as SQLDev
  rectangle "SQL*Plus (CLI)" as SQLPlus
  rectangle "Toad for Oracle" as Toad
}

package "Ferramentas PostgreSQL" as PgTools {
  rectangle "DBeaver" as DBeaver
  rectangle "pgAdmin" as PgAdmin
  rectangle "psql (CLI)" as Psql
  rectangle "DataGrip" as DataGrip
}

package "Ambiente Docker (docker compose)" as Docker {
  database "Oracle XE\ncontainer :1521" as OraDB
  database "PostgreSQL\ncontainer :5432" as PgDB
}

SQLDev --> OraDB
SQLPlus --> OraDB
Toad --> OraDB
DBeaver --> PgDB
PgAdmin --> PgDB
Psql --> PgDB
DataGrip --> PgDB
DBeaver ..> OraDB : também suporta
DataGrip ..> OraDB : também suporta
@enduml
