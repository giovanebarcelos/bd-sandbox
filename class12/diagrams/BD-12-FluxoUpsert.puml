@startuml
' BD-12-FluxoUpsert.puml
' Visualizar em: https://plantuml.com/

start
:Feed do fornecedor chega em LivroEstoqueStaging;
if (livro_id já existe em Estoque?) then (sim)
  :UPDATE: atualiza quantidade_disponivel\ne ultima_atualizacao;
else (não)
  :INSERT: cria nova linha em Estoque;
endif
:Estoque sincronizado;
note right
  Oracle: um único comando MERGE resolve as duas situações
  PostgreSQL: um único comando INSERT ... ON CONFLICT resolve as duas situações
end note
stop
@enduml
