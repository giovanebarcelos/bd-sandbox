@startuml
' BD-16-Normalizacao.puml
' Aula 16 - UA6: Formas Normais (1FN, 2FN, 3FN, BCNF)
' Decomposição passo a passo do estudo de caso MATRICULA (aluno / curso / disciplina / professor)
' Visualizar em: https://plantuml.com/

skinparam rectangle {
  BackgroundColor #F0F4F8
  BorderColor #2563EB
}

rectangle "MATRICULA não normalizada (UNF)\naluno_id, nome_aluno, cpf_aluno, curso_id, nome_curso,\nREPETE: disciplina_id, nome_disciplina, carga_horaria,\nprofessor_id, nome_professor, nota_final" as U

rectangle "MATRICULA (1FN)\nPK composta: aluno_id + disciplina_id\ntodos os atributos em uma única linha" as F1

rectangle "ALUNO\naluno_id, nome_aluno, cpf_aluno,\ncurso_id, nome_curso" as F2A
rectangle "DISCIPLINA\ndisciplina_id, nome_disciplina,\ncarga_horaria, professor_id, nome_professor" as F2B
rectangle "MATRICULA_DISCIPLINA\naluno_id, disciplina_id, nota_final" as F2C

rectangle "ALUNO\naluno_id, nome_aluno, cpf_aluno, curso_id" as F3A
rectangle "CURSO\ncurso_id, nome_curso" as F3B
rectangle "DISCIPLINA\ndisciplina_id, nome_disciplina, carga_horaria, professor_id" as F3C
rectangle "PROFESSOR\nprofessor_id, nome_professor" as F3D
rectangle "MATRICULA_DISCIPLINA\naluno_id, disciplina_id, nota_final" as F3E

rectangle "PROF_DISCIPLINA\nprofessor_id, disciplina_id" as BCNF1
rectangle "ALUNO_PROFESSOR\naluno_id, professor_id" as BCNF2

U --> F1 : 1FN: elimina grupo repetitivo

F1 --> F2A : 2FN: elimina dependência parcial
F1 --> F2B : 2FN
F1 --> F2C : 2FN

F2A --> F3A : 3FN: elimina transitiva\ncurso_id -> nome_curso
F2A --> F3B
F2B --> F3C : 3FN: elimina transitiva\nprofessor_id -> nome_professor
F2B --> F3D
F2C --> F3E

F3D --> BCNF1 : variante BCNF: professor\nleciona 1 disciplina
F3E --> BCNF2 : BCNF
@enduml
