@startuml
' BD-18-CicloExecucaoPlSql.puml
' Visualizar em: https://plantuml.com/

start
:Chamada do bloco/procedure/function;
:Seção DECLARE (opcional): variáveis,\n%TYPE, %ROWTYPE, cursores;
:Seção BEGIN: comandos SQL e PL/SQL\nexecutados em sequência;
if (Ocorreu erro?) then (não)
  :COMMIT implícito/explícito das alterações;
else (sim)
  :Seção EXCEPTION: WHEN exceção_específica\n/ WHEN OTHERS;
  :ROLLBACK ou ROLLBACK TO SAVEPOINT;
endif
:END — controle retorna ao chamador;
stop
@enduml
