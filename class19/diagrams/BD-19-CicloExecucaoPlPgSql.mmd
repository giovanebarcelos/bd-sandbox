flowchart TD
    A["Chamada: SELECT funcao(...) ou CALL procedure(...)"] --> B["DECLARE (opcional): variaveis, %TYPE, %ROWTYPE, RECORD"]
    B --> C["BEGIN: comandos SQL e PL/pgSQL executados em sequencia"]
    C --> D{"Ocorreu erro?"}
    D -- "Nao" --> E["Function: RETURN valor / RETURN QUERY | Procedure: COMMIT (se aplicavel)"]
    D -- "Sim" --> F["EXCEPTION WHEN condicao / WHEN OTHERS"]
    F --> G["RAISE NOTICE / RAISE EXCEPTION + ROLLBACK (em procedure)"]
    E --> H["END - controle retorna ao chamador"]
    G --> H
