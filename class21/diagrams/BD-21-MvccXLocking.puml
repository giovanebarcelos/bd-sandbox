@startuml
' Convertido de: BD-21-MvccXLocking.mmd
' Visualizar em: https://plantuml.com/

' Original: flowchart TB

partition "ORACLE["Oracle Database - Locking Pessimista"]" {
direction TB
:Transacao A: SELECT ... FOR UPDATE na linha X; --->> :Linha X recebe lock exclusivo;
OB --->> OC{"Transacao B tambem\npede lock na linha X?"}
OC --->>|Sim| :B fica bloqueada (blocking)\nate A executar COMMIT/ROLLBACK;
OC --->>|Nao| :B segue livre em outras linhas;
OD --->> :A executa COMMIT: libera o lock;
OF --->> :B eh liberada e prossegue\ncom dados ja atualizados;
OG --->> OH{"Ordem cruzada de locks\nentre A e B?"}
OH --->>|Sim| :Oracle detecta deadlock\nORA-00060: aborta uma transacao;
OH --->>|Nao| :Execucao serializada, sem conflito;
}
partition "POSTGRES["PostgreSQL - MVCC (Multi-Version Concurrency Control)"]" {
direction TB
:Transacao A inicia: recebe snapshot proprio; --->> :Transacao B inicia: recebe snapshot proprio;
PB --->> :A executa UPDATE na linha X:\ncria NOVA versao da tupla (xmin = A);
PC --->> :Versao antiga da linha X permanece\nvisivel para quem ja tinha snapshot anterior;
PD --->> :B le a linha X: enxerga a versao\ncompativel com o SEU snapshot, sem bloquear;
PE --->> PF{"B tambem tenta UPDATE\nna mesma linha X?"}
PF --->>|"READ COMMITTED"| :B espera A commitar,\nentao aplica sobre a versao nova;
PF --->>|"SERIALIZABLE"| :B so descobre o conflito no COMMIT:\nSQLSTATE 40001, precisa retry;
PG --->> :VACUUM remove depois\nas versoes antigas (dead tuples);
PH --->> PI
}
ORACLE -.-->|"Estrategia oposta:\nbloqueia cedo, espera"| :Locking = pessimista\n(assume conflito, trava antes);
POSTGRES -.-->|"Estrategia oposta:\nnao bloqueia leitura"| :MVCC = otimista para leitura\n(assume que nao vai conflitar);
@enduml