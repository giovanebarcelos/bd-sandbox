@startuml
' BD-27-DistribuicaoESharding.puml
' Visualizar em: https://plantuml.com/

skinparam rectangle {
  BackgroundColor #F0F4F8
  BorderColor #2563EB
}

package "Ecossistema Oracle — RAC + GoldenGate" as ORACLE {
  actor "Aplicação Cliente" as APP1
  rectangle "SCAN Listener" as SCAN
  rectangle "Instância RAC nº 1" as RAC1
  rectangle "Instância RAC nº 2" as RAC2
  rectangle "Instância RAC nº 3" as RAC3
  database "Armazenamento Compartilhado — ASM" as ASM
  rectangle "Site Remoto / DR" as DR

  APP1 --> SCAN
  SCAN --> RAC1
  SCAN --> RAC2
  SCAN --> RAC3
  RAC1 --> ASM
  RAC2 --> ASM
  RAC3 --> ASM
  RAC1 ..> DR : GoldenGate: replicação lógica
}

package "Ecossistema PostgreSQL — Streaming + Citus + Particionamento" as POSTGRES {
  actor "Aplicação Cliente" as APP2
  rectangle "Load Balancer / Pgpool / Patroni" as LB
  rectangle "Primário" as PRIMARY
  rectangle "Standby Síncrono" as STANDBY_SYNC
  rectangle "Standby Assíncrono — leitura" as STANDBY_ASYNC
  rectangle "Coordenador Citus" as COORD
  rectangle "Worker — Shard 1" as W1
  rectangle "Worker — Shard 2" as W2
  rectangle "Worker — Shard 3" as W3
  database "Partição 2025" as PART2025
  database "Partição 2026" as PART2026

  APP2 --> LB
  LB --> PRIMARY
  PRIMARY --> STANDBY_SYNC : streaming síncrona
  PRIMARY --> STANDBY_ASYNC : streaming assíncrona
  PRIMARY --> COORD
  COORD --> W1
  COORD --> W2
  COORD --> W3
  W1 ..> PART2025 : tabela particionada\npor RANGE/LIST/HASH
  W1 ..> PART2026
}

ORACLE .[#EA580C].> POSTGRES : mesma decisão arquitetural, ferramentas distintas
@enduml
