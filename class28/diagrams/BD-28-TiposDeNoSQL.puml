@startuml
' BD-28-TiposDeNoSQL.puml
' Visualizar em: https://plantuml.com/

skinparam rectangle {
  BackgroundColor #F0F4F8
  BorderColor #2563EB
}

rectangle "NoSQL — Not Only SQL" as N

rectangle "Documento" as D
rectangle "Chave-Valor" as KV
rectangle "Coluna / Wide-Column" as CF
rectangle "Grafo" as G

rectangle "MongoDB" as MONGO
rectangle "Documentos JSON/BSON\nagrupados em coleções" as D_DESC
rectangle "Caso de uso: catálogos,\nconteúdo semi-estruturado" as D_USE

rectangle "Redis" as REDIS
rectangle "Par chave -> valor opaco,\nacesso O(1)" as KV_DESC
rectangle "Caso de uso: cache, sessão, filas" as KV_USE

rectangle "Cassandra" as CASSANDRA
rectangle "Famílias de colunas distribuídas\npor partition key" as CF_DESC
rectangle "Caso de uso: séries temporais,\nIoT, alta escrita" as CF_USE

rectangle "Neo4j" as NEO4J
rectangle "Nós, relacionamentos e propriedades" as G_DESC
rectangle "Caso de uso: redes sociais,\nrecomendação, detecção de fraude" as G_USE

N --> D
N --> KV
N --> CF
N --> G

D --> MONGO
D --> D_DESC
D --> D_USE

KV --> REDIS
KV --> KV_DESC
KV --> KV_USE

CF --> CASSANDRA
CF --> CF_DESC
CF --> CF_USE

G --> NEO4J
G --> G_DESC
G --> G_USE
@enduml
