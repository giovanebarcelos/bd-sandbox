@startuml
' BD-29-CapTheorem.puml
' Visualizar em: https://plantuml.com/

skinparam rectangle {
  BackgroundColor #F0F4F8
  BorderColor #2563EB
}

rectangle "CAP Theorem\nEscolha 2 de 3 garantias\nquando a rede particiona" as CAP

rectangle "Consistency (C)\nToda leitura recebe\na escrita mais recente\nou um erro" as C
rectangle "Availability (A)\nToda requisição recebe\numa resposta (não garante\nser a mais recente)" as A
rectangle "Partition Tolerance (P)\nO sistema continua operando\nmesmo com falha de rede\nentre nós" as P

rectangle "CA\nConsistente + Disponível\nSó existe sem partição de rede\nEx.: Oracle/PostgreSQL single-node" as CA
rectangle "CP\nConsistente + Tolerante a partição\nSacrifica disponibilidade\nEx.: MongoDB (config. padrão), HBase" as CP
rectangle "AP\nDisponível + Tolerante a partição\nSacrifica consistência forte\n(consistência eventual)\nEx.: Cassandra, DynamoDB, CouchDB" as AP

CAP --> C
CAP --> A
CAP --> P

C --> CA
A --> CA
C --> CP
P --> CP
A --> AP
P --> AP
@enduml
